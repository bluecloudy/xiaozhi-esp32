# Minimal delta defaults for ESP32-S3 + 0.96 OLED + Hi Lily + Vietnamese.
# Intended to be used together with sdkconfig.defaults.esp32s3.

# Board (hardware/platform)
CONFIG_BOARD_TYPE_XINGZHI_CUBE_0_96OLED_WIFI=y

# Language: Vietnamese UI/system strings
CONFIG_LANGUAGE_VI_VN=y

# Wake model selection (engine/model only)
CONFIG_SR_WN_WN9_HILILI_TTS=y

# Keep wake model deterministic for this profile.
# CONFIG_USE_AFE_WAKE_WORD is not set
# CONFIG_SR_WN_WN9_NIHAOXIAOZHI_TTS is not set

# LVGL Graphics
CONFIG_LV_USE_SNAPSHOT=y
CONFIG_LV_USE_IMGFONT=y
CONFIG_LV_FONT_FMT_TXT_LARGE=y

# C++ exceptions and RTTI for this profile.
CONFIG_COMPILER_CXX_EXCEPTIONS=y
CONFIG_COMPILER_CXX_EXCEPTIONS_EMG_POOL_SIZE=1024
CONFIG_COMPILER_CXX_RTTI=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/v2/16m.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000