# Minimal delta defaults for ESP32-S3 + 0.96 OLED + Hi Lily + Vietnamese.
# Intended to be used together with sdkconfig.defaults.esp32s3.

# Board: Xingzhi Cube 0.96 OLED (WiFi)
CONFIG_BOARD_TYPE_XINGZHI_CUBE_0_96OLED_WIFI=y

# Language: Vietnamese UI/system strings
CONFIG_LANGUAGE_VI_VN=y

# Wake word engine: custom Multinet path
# CONFIG_USE_CUSTOM_WAKE_WORD=y

# Wake phrase uses phonetic-like tokens for English Multinet model
# CONFIG_CUSTOM_WAKE_WORD="li li"
# CONFIG_CUSTOM_WAKE_WORD_DISPLAY="Hi Lily"

# Keep language explicit for custom wake model path
# CONFIG_CUSTOM_WAKE_WORD_LANG_EN=y
# CONFIG_SR_MN_EN_MULTINET5_SINGLE_RECOGNITION_QUANT8=y

# Ensure AFE/default wake models are not selected in this profile
# CONFIG_USE_AFE_WAKE_WORD is not set
# CONFIG_SR_WN_WN9_HILILI_TTS is not set
# CONFIG_SR_WN_WN9_NIHAOXIAOZHI_TTS is not set

CONFIG_SR_WN_WN9_HILILI_TTS=y