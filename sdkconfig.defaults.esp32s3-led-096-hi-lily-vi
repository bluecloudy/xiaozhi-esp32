# Minimal delta defaults for ESP32-S3 + 0.96 OLED + Hi Lily + Vietnamese.
# Intended to be used together with sdkconfig.defaults.esp32s3.

# Board: Xingzhi Cube 0.96 OLED (WiFi)
CONFIG_BOARD_TYPE_XINGZHI_CUBE_0_96OLED_WIFI=y

# Language: Vietnamese UI/system strings
CONFIG_LANGUAGE_VI_VN=y

# Wake word engine for ESP32-S3 + PSRAM boards
CONFIG_USE_AFE_WAKE_WORD=y

# Wake word model: "Hi Lily"
CONFIG_SR_WN_WN9_HILILI_TTS=y

# Ensure default wake model is not selected in this profile
# CONFIG_SR_WN_WN9_NIHAOXIAOZHI_TTS is not set
